{
    "name": "business-directory",
    "version": "1.0.0",
    "description": "Business Directory Platform",
    "main": "server/src/index.js",
    "type": "module",
    "scripts": {
        "server": "npm run dev --prefix server",
        "client": "npm run dev --prefix client",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "build": "CI=false npm install --no-audit --no-fund && npm install --prefix client --no-audit --no-fund && npm run build --prefix client",
        "start": "node server/src/index.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cloudinary": "^2.0.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-async-handler": "^1.2.0",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.2.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^6.9.10",
        "resend": "^6.10.0"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}
